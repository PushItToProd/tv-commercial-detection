## llama.cpp

LLAMA_PORT=3002

# Uncomment the following to pass extra args to llama.cpp. For example, you
# might want to set a larger context size or use multiple threads for faster
# inference. See the llama.cpp documentation for available options.

# LLAMA_EXTRA_ARGS=--ctx-size 4096 -b 4096 --ubatch-size 4096 -np 2

# The directory on the host machine where models are stored. This is mounted
# into the llama container at /models, so paths to model files in the config
# should be relative to this directory.
MODELS_HOST_DIR=/mnt/data/llm-models

# Model and mmproj file names (paths should be relative to MODELS_HOST_DIR)
MODEL_FILE=Qwen3.5-4B-Q4_K_M.gguf
MMPROJ_FILE=Qwen3.5-4B-GGUF-mmproj-BF16.gguf

## HDMI matrix control server

HDMI_MATRIX_CONTROL_DIR=$HOME/Code/projects/portta-multiviewer-control
HDMI_MATRIX_SERIAL_PORT=/dev/ttyACM0
HDMI_MATRIX_CONTROL_PORT=5000

## Receiver server config

RECEIVER_DIR=./server
RECEIVER_ENABLE_DEBOUNCE=1
